SUPABASE_URL=
SUPABASE_KEY=

# JWT secret used to sign tokens
JWT_SECRET=change-me

# Optional SMTP settings to send real emails. If left unset, the server will log reset tokens instead of sending.
# Use a transactional email provider (Mailtrap, SendGrid SMTP, etc.) in testing.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM=PC Store <noreply@example.com>

# Frontend URL used to build the reset link
FRONTEND_URL=http://localhost:4200
# Copy this file to .env and fill real values for local development
# Supabase (required for DB operations)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# JWT secret for signing tokens
JWT_SECRET=change-this-secret

# Frontend URL used in emails / links
FRONTEND_URL=http://localhost:4200

# Optional SMTP settings for sending emails
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@pcstore.local

# Server port
PORT=3000
