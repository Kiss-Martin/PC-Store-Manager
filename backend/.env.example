# Copy this file to .env and fill real values.

# ---- Required ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# JWT secret — MUST be changed in production (min 32 chars recommended)
JWT_SECRET=change-this-secret

# ---- App runtime ----
NODE_ENV=development
PORT=3000
# TRUST_PROXY=false

# Frontend URL (used for CORS, email links, redirects)
# Local: http://localhost:4200
# Production example: https://pc-store-manager-frontend.onrender.com
FRONTEND_URL=https://pc-store-manager-frontend.onrender.com

# Backend URL (used for one-click email action links)
# BACKEND_URL=http://localhost:3000

# Comma-separated CORS origins (overrides defaults when set)
# CORS_ORIGINS=https://pc-store-manager-frontend.onrender.com,http://localhost:4200

# ---- SMTP (optional — emails logged to console if not configured) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pcstorenoreply4@gmail.com
SMTP_PASS=your-gmail-app-password
# Gmail can always send with a custom display name, for example:
# SMTP_FROM=PC Store Manager <pcstorenoreply4@gmail.com>
# A true noreply address such as noreply@your-domain.com only works if
# that address is configured as a verified Gmail alias / Google Workspace sender.
SMTP_FROM=PC Store Manager <pcstorenoreply4@gmail.com>

# Support inbox for contact form
# SUPPORT_EMAIL=support@yourcompany.com

# Separate secret for refresh token hashing (falls back to JWT_SECRET)
# REFRESH_TOKEN_SECRET=
