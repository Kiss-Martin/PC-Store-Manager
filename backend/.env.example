# Copy this file to .env and fill real values.

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key

# App runtime
JWT_SECRET=change-this-secret
NODE_ENV=development
PORT=3000

# Frontend URL used to build password reset links
# Local: http://localhost:4200
# Production example: https://pc-store-manager-frontend.onrender.com
FRONTEND_URL=https://pc-store-manager-frontend.onrender.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=pcstorenoreply4@gmail.com
SMTP_PASS=your-gmail-app-password
# Gmail can always send with a custom display name, for example:
# SMTP_FROM=PC Store Manager <pcstorenoreply4@gmail.com>
# A true noreply address such as noreply@your-domain.com only works if
# that address is configured as a verified Gmail alias / Google Workspace sender.
SMTP_FROM=PC Store Manager <pcstorenoreply4@gmail.com>
